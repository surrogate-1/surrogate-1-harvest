#!/usr/bin/env bash
# `surrogate` — Claude-Code-style CLI
set -u
set -a; source "$HOME/.hermes/.env" 2>/dev/null; set +a

# ═══ Colors ═══
R=$'\033[0m'; D=$'\033[2m'; B=$'\033[1m'
CY=$'\033[36m'; GR=$'\033[32m'; YE=$'\033[33m'
MA=$'\033[35m'; RE=$'\033[31m'; GY=$'\033[90m'
BCY=$'\033[96m'; BMA=$'\033[95m'

# ═══ ~/.surrogate/ init (run once on first launch) ═══
SURROGATE_HOME="$HOME/.surrogate"
init_surrogate_home() {
    mkdir -p "$SURROGATE_HOME"/{sessions,memory,projects,specs,checkpoints,worktrees}
    # settings.json — like Claude Code's settings
    if [[ ! -f "$SURROGATE_HOME/settings.json" ]]; then
        cat > "$SURROGATE_HOME/settings.json" <<'JSON'
{
  "model": "auto",
  "effort": "medium",
  "maxSteps": 15,
  "permissionMode": "default",
  "autoCommit": true,
  "planDriven": true,
  "budget": {
    "dailyMaxUsd": 2.0,
    "warnAtUsd": 1.5
  },
  "agents": ["architect","dev","qa","ops","reviewer"],
  "memory": {
    "episodesFile": "~/.claude/state/surrogate-memory/episodes.jsonl",
    "projectFiles": "~/.surrogate/projects"
  }
}
JSON
    fi
    # SURROGATE.md template for new projects
    if [[ ! -f "$SURROGATE_HOME/SURROGATE.md.template" ]]; then
        cat > "$SURROGATE_HOME/SURROGATE.md.template" <<'MD'
# Project Instructions for Surrogate

## Project
<!-- Brief description of this project -->

## Tech Stack
<!-- Languages, frameworks, infra -->

## Coding Standards
<!-- Naming, style, patterns to follow -->

## Key Files
<!-- Important files the agent should know about -->

## Constraints
<!-- Things NOT to do, security rules, cost limits -->

## Auto-Dev Plan
<!-- Tasks for --auto mode. Format: "- [ ] task description" -->

MD
    fi
}
init_surrogate_home

# ═══ Detect SURROGATE.md (like CLAUDE.md) from CWD upward ═══
find_surrogate_md() {
    local dir="$1"
    while [[ "$dir" != "/" && "$dir" != "$HOME" ]]; do
        if [[ -f "$dir/SURROGATE.md" ]]; then
            echo "$dir/SURROGATE.md"; return
        fi
        dir=$(dirname "$dir")
    done
    # Also check home-level
    [[ -f "$HOME/SURROGATE.md" ]] && echo "$HOME/SURROGATE.md"
}
SURROGATE_MD=$(find_surrogate_md "$(pwd)")
SURROGATE_MD_CONTENT=""
if [[ -n "$SURROGATE_MD" ]]; then
    SURROGATE_MD_CONTENT=$(cat "$SURROGATE_MD" 2>/dev/null | head -200)
fi
export SURROGATE_MD_CONTENT

# ═══ Default opts ═══
PROMPT=""
PRINT_ONLY=0
MODEL=""
EFFORT="medium"
MAX_STEPS=15
MODE="interactive"
PERM_MODE="default"    # default | plan | auto | yolo | acceptEdits
RESUME=""
WORKTREE=""

# ═══ Args ═══
while [[ $# -gt 0 ]]; do
    case "$1" in
        -p|--print) PRINT_ONLY=1; MODE="print"; shift ;;
        --model) MODEL="$2"; shift 2 ;;
        --effort) EFFORT="$2"; shift 2 ;;
        --max-steps) MAX_STEPS="$2"; shift 2 ;;
        -c|--continue) RESUME="last"; shift ;;
        -r|--resume) RESUME="${2:-last}"; shift 2 ;;
        --auto|--auto-dev) MODE="auto-dev"; shift ;;
        --monitor) MODE="monitor"; shift ;;
        --plan) PERM_MODE="plan"; MODE="plan-mode"; shift ;;
        --yolo|--bypass-permissions) PERM_MODE="yolo"; shift ;;
        --accept-edits) PERM_MODE="acceptEdits"; shift ;;
        --permission-mode) PERM_MODE="$2"; shift 2 ;;
        --worktree|-w) WORKTREE="${2:-feature}"; shift 2 ;;
        --status) MODE="status"; shift ;;
        --agents) MODE="agents"; shift ;;
        --version|-v) echo "Surrogate-1 v2.2.0 (mirror claude-code 2.2)"; exit 0 ;;
        -h|--help) MODE="help"; shift ;;
        init) MODE="init-project"; shift ;;
        plan)
            # surrogate plan set <file> | show | clear
            bash ~/.claude/bin/surrogate-daemon.sh plan "$@"
            exit 0
            ;;
        .) shift ;;
        *) PROMPT="$*"; MODE="print"; break ;;
    esac
done

# ═══ Banner (Claude-style) ═══
banner() {
cat <<EOF
${BCY}${B} ░██████╗██╗░░░██╗██████╗░██████╗░░█████╗░░██████╗░░█████╗░████████╗███████╗${R}
${BCY}${B} ██╔════╝██║░░░██║██╔══██╗██╔══██╗██╔══██╗██╔════╝░██╔══██╗╚══██╔══╝██╔════╝${R}
${BCY}${B} ╚█████╗░██║░░░██║██████╔╝██████╔╝██║░░██║██║░░██╗░███████║░░░██║░░░█████╗░░${R}
${BCY}${B} ░╚═══██╗██║░░░██║██╔══██╗██╔══██╗██║░░██║██║░░╚██╗██╔══██║░░░██║░░░██╔══╝░░${R}
${BCY}${B} ██████╔╝╚██████╔╝██║░░██║██║░░██║╚█████╔╝╚██████╔╝██║░░██║░░░██║░░░███████╗${R}
${BCY}${B} ╚═════╝░░╚═════╝░╚═╝░░╚═╝╚═╝░░╚═╝░╚════╝░░╚═════╝░╚═╝░░╚═╝░░░╚═╝░░░╚══════╝${R}
${D}                          — AI assistant CLI ${MA}● ${GR}v2${D} — ${R}

${D}cwd: ${R}${B}$(pwd)${R}
${D}mode: ${R}${YE}${PERM_MODE}${R} ${D}| effort: ${R}${YE}$EFFORT${R} ${D}| max_steps: ${R}${YE}$MAX_STEPS${R}
${D}project: ${R}${GR}${SURROGATE_MD:-"(no SURROGATE.md)"}${R}
${D}slash commands: ${R}${GR}/help /auto /plan /yolo /mode /status /monitor${R}
${D}Tab to cycle modes: plan → auto → yolo → default${R}
EOF
}

help_text() {
cat <<EOF

${B}surrogate${R} — Claude-Code-style CLI

${B}Modes:${R}
  ${GR}surrogate${R}                   interactive REPL (default)
  ${GR}surrogate "prompt"${R}          one-shot task
  ${GR}surrogate -p "prompt"${R}       print only
  ${GR}surrogate --auto              auto-dev — chain architect→dev→qa→reviewer
  ${GR}surrogate --monitor${R}         daemon — watch cloud/system, auto-fix issues
  ${GR}surrogate .${R}                 use current directory (default anyway)

${B}Options:${R}
  ${YE}--model${R} <m>                qwen3-coder|claude-haiku-4.5|gemini-2.5-flash
  ${YE}--effort${R} <l>               low|medium|high
  ${YE}--max-steps${R} <n>            tool-loop cap (default 15)
  ${YE}-c${R}, ${YE}--continue${R}               resume last session
  ${YE}-r${R}, ${YE}--resume${R} [id]           resume session by id
  ${YE}-w${R}, ${YE}--worktree${R} [name]       create git worktree for this session

${B}Commands:${R}
  ${CY}--status${R}                    session + corpus stats
  ${CY}--agents${R}                    list agents
  ${CY}--version${R}                   show version

${B}Slash commands (in REPL):${R}
  /help /status /agents /auto /monitor /clear /model <m>
  /mcp /plugins /memory /cost

${B}Project (Claude Projects equivalent):${R}
  ${CY}surrogate init${R}                   create SURROGATE.md for this project
  ${CY}surrogate plan set plan.md${R}        set active plan → daemon drives tasks from it
  ${CY}surrogate plan show${R}               show plan progress (✅/🔄/⏳)
  ${CY}surrogate plan clear${R}              clear active plan

${B}Examples:${R}
  cd ~/axentx/Vanguard && surrogate "ดู plan แล้วเขียน code ให้จบ"
  surrogate --auto                  # plan-driven auto: reads ~/.surrogate/active-plan.md
  surrogate --monitor               # watches logs + self-heals
  surrogate -c "ต่อที่คุยไว้"       # continue last session
  surrogate init                    # scaffold SURROGATE.md for this project
  surrogate plan set TODO.md        # set active plan from markdown checklist

EOF
}

# ═══ Agent runner (streams tool calls) ═══
run_agent() {
    local task="$1"
    export AGENT_TASK="$task"
    export AGENT_MAX_STEPS="$MAX_STEPS"
    export AGENT_MODEL_OVERRIDE="$MODEL"
    export AGENT_EFFORT="$EFFORT"
    export AGENT_CWD="$(pwd)"

    python3 <<'PYEOF'
import os, sys, json, re, sqlite3, subprocess, urllib.request, urllib.error, time
from datetime import datetime
from pathlib import Path

C = {'R':'\033[0m','D':'\033[2m','B':'\033[1m',
     'C':'\033[36m','G':'\033[32m','Y':'\033[33m',
     'M':'\033[35m','RED':'\033[31m','GRAY':'\033[90m'}

TASK = os.environ['AGENT_TASK']
MAX_STEPS = int(os.environ['AGENT_MAX_STEPS'])
MODEL_OVERRIDE = os.environ.get('AGENT_MODEL_OVERRIDE','')
CWD = os.environ.get('AGENT_CWD', '.')
OR_KEY = os.environ.get('OPENROUTER_API_KEY','')
GEMINI = os.environ.get('GEMINI_API_KEY','')
GEMINI2 = os.environ.get('GEMINI_API_KEY_2','')
GH_POOL = [t.strip() for t in os.environ.get('GITHUB_TOKEN_POOL','').split(',') if t.strip()]

MEM_DIR = Path(os.path.expanduser('~/.claude/state/surrogate-memory'))
MEM_DIR.mkdir(parents=True, exist_ok=True)
EPISODES = MEM_DIR / 'episodes.jsonl'

sys_prompt_path = Path(os.path.expanduser('~/axentx/surrogate/system-prompt.md'))
SYS_PROMPT = sys_prompt_path.read_text()[:10000] if sys_prompt_path.exists() else ''

# Inject SURROGATE.md (project-level instructions, like Claude Projects)
surrogate_md = os.environ.get('SURROGATE_MD_CONTENT', '')
if surrogate_md.strip():
    SYS_PROMPT += f'\n\n## Project Instructions (SURROGATE.md)\n{surrogate_md[:3000]}'

# ═══ Tools ═══
def tool_bash(cmd, timeout=60, cwd=None):
    try:
        r = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=timeout, cwd=cwd or CWD)
        return {'stdout': r.stdout[:5000], 'stderr': r.stderr[:1500], 'rc': r.returncode}
    except Exception as e: return {'error': str(e)}

def tool_read(path, limit=2000, offset=0):
    try:
        p = Path(os.path.expanduser(path)).resolve()
        if not p.exists(): p = (Path(CWD)/path).resolve()
        if p.is_dir(): return {'items': [f.name for f in sorted(p.iterdir())][:80]}
        lines = p.read_text(errors='replace').splitlines()
        return {'path':str(p), 'content':'\n'.join(lines[offset:offset+limit])[:20000], 'total_lines':len(lines)}
    except Exception as e: return {'error':str(e)}

def tool_write(path, content):
    try:
        p = Path(os.path.expanduser(path)) if path.startswith(('/','~')) else Path(CWD)/path
        p.parent.mkdir(parents=True, exist_ok=True)
        p.write_text(content)
        return {'path':str(p),'bytes':len(content),'ok':True}
    except Exception as e: return {'error':str(e)}

def tool_edit(path, old_string, new_string):
    try:
        p = Path(os.path.expanduser(path)) if path.startswith(('/','~')) else Path(CWD)/path
        t = p.read_text()
        if old_string not in t: return {'error':'old_string not found'}
        if t.count(old_string)>1: return {'error':f'ambiguous ({t.count(old_string)})'}
        p.write_text(t.replace(old_string,new_string,1))
        return {'path':str(p),'ok':True}
    except Exception as e: return {'error':str(e)}

def tool_glob(pattern, path=None):
    import glob as gl
    base = os.path.expanduser(path) if path else CWD
    m = gl.glob(os.path.join(base,pattern), recursive=True)[:100]
    return {'count':len(m), 'matches':m}

def tool_grep(pattern, path=None, glob='*'):
    base = os.path.expanduser(path) if path else CWD
    cmd = f"/usr/bin/grep -rn --include='{glob}' -E {subprocess.list2cmdline([pattern])} {base} 2>/dev/null | head -40"
    r = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=15)
    return {'matches': r.stdout[:5000]}

def tool_rag_query(query, limit=5):
    try:
        conn = sqlite3.connect(os.path.expanduser('~/.claude/index.db'))
        kw = ' '.join(w for w in re.sub(r'[^a-zA-Z0-9ก-๙ ]',' ',query.lower()).split() if len(w)>2)[:200]
        rows = conn.execute("SELECT d.source, d.path, substr(d.response,1,500) FROM docs_fts f JOIN docs d ON d.id=f.rowid WHERE f.docs_fts MATCH ? ORDER BY bm25(docs_fts) LIMIT ?", (kw,limit)).fetchall()
        conn.close()
        return {'results':[{'source':s,'path':p or '','text':b[:400]} for s,p,b in rows]}
    except Exception as e: return {'error':str(e)}

TOOLS = {'bash':tool_bash,'read':tool_read,'write':tool_write,'edit':tool_edit,
         'glob':tool_glob,'grep':tool_grep,'rag_query':tool_rag_query}

def render_call(name, args):
    a = ', '.join(f'{k}={json.dumps(v,ensure_ascii=False)[:40]}' for k,v in args.items())
    return f"{C['C']}●{C['R']} {C['B']}{name}{C['R']}({C['GRAY']}{a}{C['R']})"

def render_result(r):
    if 'error' in r: return f"  {C['RED']}⎿ err: {str(r['error'])[:120]}{C['R']}"
    if 'content' in r: return f"  {C['GRAY']}⎿ Read {r.get('total_lines',0)} lines{C['R']}"
    if r.get('ok'): return f"  {C['G']}⎿ Wrote {r.get('bytes','?')} bytes → {r.get('path','')}{C['R']}"
    if 'matches' in r:
        if isinstance(r['matches'],list): return f"  {C['GRAY']}⎿ {r.get('count',len(r['matches']))} match(es){C['R']}"
        return f"  {C['GRAY']}⎿ {r['matches'].count(chr(10))} grep match(es){C['R']}"
    if 'results' in r: return f"  {C['GRAY']}⎿ {len(r['results'])} hit(s){C['R']}"
    if 'stdout' in r:
        prev = r['stdout'].strip().split('\n')[0][:100] if r['stdout'].strip() else '(empty)'
        return f"  {C['GRAY']}⎿ rc={r['rc']} — {prev}{C['R']}"
    if 'items' in r: return f"  {C['GRAY']}⎿ {len(r['items'])} items{C['R']}"
    return f"  {C['GRAY']}⎿ ok{C['R']}"

# ═══ LLM ladder ═══
def to_gemini(msgs):
    contents, sys_txt = [], ''
    for m in msgs:
        if m['role']=='system': sys_txt = m['content']
        else: contents.append({'role':'user' if m['role']=='user' else 'model','parts':[{'text':m['content']}]})
    if sys_txt and contents and contents[0]['role']=='user':
        contents[0]['parts'][0]['text'] = sys_txt + '\n\n---\n\n' + contents[0]['parts'][0]['text']
    return contents

def llm(messages):
    def try_gem(k, m='gemini-2.5-flash'):
        url = f'https://generativelanguage.googleapis.com/v1beta/models/{m}:generateContent?key={k}'
        body = {'contents':to_gemini(messages),'generationConfig':{'temperature':0.2,'maxOutputTokens':3000}}
        req = urllib.request.Request(url,data=json.dumps(body).encode(),headers={'Content-Type':'application/json'})
        with urllib.request.urlopen(req,timeout=90) as r:
            return json.load(r)['candidates'][0]['content']['parts'][0]['text']
    def try_oai(url, model, key):
        body = {'model':model,'messages':messages,'temperature':0.2,'max_tokens':3000,'stream':False}
        headers = {'Content-Type':'application/json','Authorization':f'Bearer {key}'}
        if 'openrouter' in url: headers.update({'HTTP-Referer':'https://axentx.ai','X-Title':'Surrogate-1'})
        req = urllib.request.Request(url,data=json.dumps(body).encode(),headers=headers)
        with urllib.request.urlopen(req,timeout=90) as r:
            return json.load(r)['choices'][0]['message']['content']

    def try_ollama(model='surrogate-1'):
        # Local Ollama fallback — last resort when ALL cloud providers fail.
        # Uses OpenAI-compatible endpoint at localhost:11434/v1.
        body = {'model':model,'messages':messages,'temperature':0.2,'max_tokens':3000,'stream':False,'keep_alive':'5m'}
        req = urllib.request.Request('http://localhost:11434/v1/chat/completions',
            data=json.dumps(body).encode(),
            headers={'Content-Type':'application/json'})
        with urllib.request.urlopen(req,timeout=180) as r:
            return json.load(r)['choices'][0]['message']['content']

    ladder = []
    if GEMINI: ladder.append(('gemini',lambda: try_gem(GEMINI)))
    if GEMINI2: ladder.append(('gemini2',lambda: try_gem(GEMINI2)))
    if OR_KEY:
        for m in ['qwen/qwen3-coder','anthropic/claude-haiku-4.5','qwen/qwen3-235b-a22b-2507','google/gemini-2.5-flash']:
            ladder.append((f'or:{m}',lambda m=m: try_oai('https://openrouter.ai/api/v1/chat/completions',m,OR_KEY)))
    for t in GH_POOL[:4]:
        ladder.append(('gh-models',lambda t=t: try_oai('https://models.github.ai/inference/chat/completions','openai/gpt-4o-mini',t)))
    # Final fallback: local Ollama (Surrogate-1 / gemma4:e4b base) — never costs, never rate-limited
    ladder.append(('ollama:surrogate-1', lambda: try_ollama('surrogate-1')))
    ladder.append(('ollama:gemma4:e4b', lambda: try_ollama('gemma4:e4b')))
    if MODEL_OVERRIDE and OR_KEY:
        ladder.insert(0,('override',lambda: try_oai('https://openrouter.ai/api/v1/chat/completions',MODEL_OVERRIDE,OR_KEY)))
    errs = []
    for name, fn in ladder:
        try: return fn()
        except Exception as e:
            errs.append(f"{name}:{type(e).__name__}")
            continue
    raise RuntimeError(f"providers exhausted ({len(ladder)}); errors: {','.join(errs[:5])}")

def enforce_male(t):
    for p, r in [('ดิฉัน','ผม'),(r'ฉัน(?![a-zA-Z])','ผม'),('ค่ะ','ครับ'),('นะคะ','นะครับ'),('คะ','ครับ'),('จ้า','ครับ')]:
        t = re.sub(p, r, t)
    return t

# ═══ Loop ═══
agent_sys = SYS_PROMPT + f"""

## Tool-use
Use tools autonomously — DON'T tell user to run commands.
Tools: bash, read, write, edit, glob, grep, rag_query.
Call exactly 1 tool per turn via:
```tool
{{"name":"...","args":{{"...":"..."}}}}
```
Final answer = plain text (no tool block).

CWD: {CWD}
Max steps: {MAX_STEPS}
"""
messages = [
    {'role':'system','content':agent_sys},
    {'role':'user','content':TASK}
]
print(f"{C['GRAY']}⏺ thinking...{C['R']}",flush=True)
step, final = 0, None
while step < MAX_STEPS:
    step += 1
    try: resp = llm(messages)
    except Exception as e:
        print(f"{C['RED']}✗ {e}{C['R']}"); break
    resp = enforce_male(resp)
    tm = re.search(r'```tool\s*\n(.+?)\n```', resp, re.DOTALL)
    if not tm:
        final = resp; print(); print(resp)
        try:
            with open(EPISODES,'a') as f:
                f.write(json.dumps({'ts':datetime.utcnow().isoformat(),'task':TASK[:500],'steps':step,'final':resp[:3000]},ensure_ascii=False)+'\n')
        except: pass
        break
    try:
        call = json.loads(tm.group(1))
        name, args = call['name'], call.get('args',{})
    except Exception as e:
        print(f"{C['RED']}⚠ bad tool JSON{C['R']}"); break
    if name not in TOOLS:
        print(f"{C['RED']}⚠ unknown tool: {name}{C['R']}")
        messages.append({'role':'assistant','content':resp})
        messages.append({'role':'user','content':f'[error] tool {name} unknown'})
        continue
    print(render_call(name,args))
    try: result = TOOLS[name](**args)
    except Exception as e: result = {'error':str(e)}
    print(render_result(result))
    messages.append({'role':'assistant','content':resp})
    messages.append({'role':'user','content':f'[tool:{name}]\n{json.dumps(result,ensure_ascii=False)[:3000]}'})
if final is None:
    print(f"\n{C['Y']}⚠ max_steps reached{C['R']}")
PYEOF
}

# ═══ REPL ═══
repl() {
    banner
    echo ""
    while true; do
        echo -en "${B}${BMA}▶${R} "
        if ! IFS= read -r line; then echo ""; break; fi
        [[ -z "$line" ]] && continue
        case "$line" in
            /exit|/quit|exit|quit) break ;;
            /help) help_text ;;
            /status) bash "$0" --status ;;
            /clear) clear; banner; echo "" ;;
            /agents) bash "$0" --agents ;;
            /auto|/auto-dev)
                echo "${GR}▶ switching to AUTO-DEV mode${R}"
                TASK=$(echo "$line" | sed 's|^/[a-z-]* *||')
                [[ -n "$TASK" ]] && bash "$0" --auto-dev "$TASK" || bash "$0" --auto-dev
                ;;
            /plan*)
                TASK=$(echo "$line" | sed 's|^/plan *||')
                bash "$0" --plan -p "$TASK"
                ;;
            /yolo*)
                TASK=$(echo "$line" | sed 's|^/yolo *||')
                PERM_MODE=yolo run_agent "$TASK"
                ;;
            /monitor) echo "${YE}→ monitor mode...${R}"; bash "$0" --monitor & ;;
            /model*) NEW=$(echo "$line" | awk '{print $2}'); MODEL="$NEW"; echo "${GR}✓ model → $NEW${R}" ;;
            /mode*)
                NEW=$(echo "$line" | awk '{print $2}')
                case "$NEW" in
                    plan|auto|yolo|default|acceptEdits) PERM_MODE="$NEW"; echo "${GR}✓ mode → $NEW${R}" ;;
                    *) echo "${GY}valid: plan | auto | yolo | default | acceptEdits${R}" ;;
                esac
                ;;
            /memory) ls -lh ~/.claude/state/surrogate-memory/ 2>&1 | head -10 ;;
            /cost)
                bash -c 'source ~/.hermes/.env; curl -s -H "Authorization: Bearer $OPENROUTER_API_KEY" https://openrouter.ai/api/v1/auth/key' 2>&1 | python3 -c "import json,sys; d=json.load(sys.stdin).get('data',{}); print(f'  OpenRouter: \${d.get(\"usage\",0):.4f}')"
                ;;
            /*) echo "${GY}unknown: $line — try /help${R}" ;;
            *)  run_agent "$line" ;;
        esac
        echo ""
    done
    echo "${D}session ended${R}"
}

# ═══ Init project — scaffold SURROGATE.md ═══
init_project() {
    local target="$(pwd)/SURROGATE.md"
    if [[ -f "$target" ]]; then
        echo "${YE}⚠ SURROGATE.md already exists at $target${R}"
        echo -en "Overwrite? [y/N] "; read -r ans
        [[ "$ans" != "y" && "$ans" != "Y" ]] && exit 0
    fi
    cp "$SURROGATE_HOME/SURROGATE.md.template" "$target"
    echo "${GR}✅ Created ${target}${R}"
    echo "${D}  Edit it to add project instructions + plan tasks.${R}"
    echo "${D}  Then: surrogate plan set SURROGATE.md${R}"
}

# ═══ Auto-Dev mode — plan-driven or interactive ═══
auto_dev_mode() {
    local task="${1:-}"

    # Check for active plan first (plan-driven, no interactive prompt needed)
    PLAN_FILE="$SURROGATE_HOME/active-plan.md"
    if [[ -z "$task" && -f "$PLAN_FILE" ]]; then
        PENDING=$(grep -c '^\- \[ \]' "$PLAN_FILE" 2>/dev/null || echo 0)
        DONE=$(grep -c '^\- \[x\]' "$PLAN_FILE" 2>/dev/null || echo 0)
        echo "${B}${GR}▶ AUTO-DEV MODE (plan-driven)${R}"
        echo "${D}  Plan: $PLAN_FILE  ✅ done=$DONE  ⏳ pending=$PENDING${R}"
        echo "${D}  Pipeline: architect → dev → qa → reviewer  |  Ctrl+C to stop${R}"
        echo ""
        # Drive tasks from plan until all done
        while true; do
            # Pop next pending task from plan
            NEXT_TASK=$(python3 <<'PYEOF'
import sys, re
from pathlib import Path
plan_file = Path.home() / '.surrogate' / 'active-plan.md'
if not plan_file.exists(): sys.exit(0)
text = plan_file.read_text()
match = re.search(r'^- \[ \] (.+)', text, re.MULTILINE)
if not match: sys.exit(0)
task_text = match.group(1).strip()
# Mark in-progress
new_text = text.replace(f'- [ ] {task_text}', f'- [~] {task_text}', 1)
plan_file.write_text(new_text)
print(task_text)
PYEOF
)
            [[ -z "$NEXT_TASK" ]] && { echo "${GR}✅ Plan complete — all tasks done!${R}"; break; }
            echo "${BCY}${B}▸ Next task:${R} $NEXT_TASK"
            bash ~/.claude/bin/surrogate-orchestrate.sh "$NEXT_TASK"
            # Mark done in plan
            python3 <<PYEOF
from pathlib import Path
plan_file = Path.home() / '.surrogate' / 'active-plan.md'
if plan_file.exists():
    text = plan_file.read_text()
    plan_file.write_text(text.replace(f'- [~] $NEXT_TASK', f'- [x] $NEXT_TASK', 1))
PYEOF
            echo ""
        done
        return
    fi

    # No plan — interactive or one-shot
    if [[ -z "$task" ]]; then
        echo "${B}${GR}▶ AUTO-DEV MODE${R}"
        echo "${D}  Pipeline: architect → dev → qa → ops? → reviewer${R}"
        echo "${D}  Tip: 'surrogate plan set <file>' for plan-driven automation${R}"
        echo "${D}  Type task, or /exit to quit${R}"
        echo ""
        while true; do
            echo -en "${B}${BMA}▶ auto-dev >${R} "
            if ! IFS= read -r line; then echo ""; break; fi
            [[ -z "$line" ]] && continue
            [[ "$line" == "/exit" || "$line" == "exit" ]] && break
            bash ~/.claude/bin/surrogate-orchestrate.sh "$line"
            echo ""
        done
    else
        bash ~/.claude/bin/surrogate-orchestrate.sh "$task"
    fi
}

# ═══ Plan mode — architect only (no code changes) ═══
plan_mode() {
    local task="${1:-}"
    if [[ -z "$task" ]]; then
        echo -en "${B}${YE}▶ plan >${R} "
        read -r task
    fi
    bash ~/.claude/bin/surrogate-orchestrate.sh --mode plan "$task"
}

# ═══ Monitor mode (watch cloud/logs, auto-fix) ═══
monitor_mode() {
    echo "${B}${MA}▶ MONITOR MODE${R}"
    echo "${D}  Watching ~/.claude/logs/, ~/.hermes/workspace/healer/, system load.${R}"
    echo "${D}  Ctrl+C to stop.${R}"
    echo ""
    ITER=0
    while true; do
        ITER=$((ITER+1))
        clear
        banner
        echo "${B}▶ MONITOR #$ITER @ $(date +%H:%M:%S)${R}"
        echo ""
        # System health
        LOAD=$(uptime | awk -F'load averages:' '{print $2}' | awk '{print $1}')
        FREE=$(vm_stat | awk '/Pages free/{gsub("[.]","",$3); printf "%d", ($3*16384)/1048576}')
        echo "${B}system${R}  load=$LOAD  free=${FREE}MB"
        # Daemon
        PROCS=$(pgrep -cf "surrogate-daemon\|github-domain-scrape\|domain-scrape-loop" 2>/dev/null)
        echo "${B}daemon${R}  procs=$PROCS"
        # Recent healer fires
        echo "${B}healer${R}  last 3 actions:"
        ls -t ~/.hermes/workspace/healer/*.md 2>/dev/null | head -3 | awk '{print "  " $0}' | xargs -I{} basename {} 2>/dev/null | sed 's/^/  /'
        # Training + graph
        PAIRS=$(wc -l ~/axentx/surrogate/data/training-jsonl/*.jsonl 2>/dev/null | tail -1 | awk '{print $1}')
        REPOS=$(sqlite3 ~/.claude/state/scrape-ledger.db "SELECT COUNT(*) FROM scraped" 2>/dev/null)
        echo "${B}data${R}    pairs=$PAIRS  repos=$REPOS"
        # Recent errors in logs (auto-heal trigger)
        ERR_COUNT=$(tail -200 ~/.claude/logs/*.log 2>/dev/null | grep -cE "ERROR|Fatal|CRITICAL|429|403|500" || echo 0)
        echo "${B}errors${R}  last 200 log lines: $ERR_COUNT"
        # If critical → spawn agent to investigate
        if [[ $ERR_COUNT -gt 50 ]]; then
            echo "${RE}⚠ elevated errors — dispatching investigator agent${R}"
            (run_agent "เช็ค ~/.claude/logs/ หา pattern error ที่ recur บ่อย และเสนอ fix list (ห้ามแก้เอง รายงานอย่างเดียว)" 2>&1 | /usr/bin/head -20) &
        fi
        sleep 30
    done
}

# ═══ Status ═══
show_status() {
    banner
    echo ""
    REPOS=$(sqlite3 ~/.claude/state/scrape-ledger.db "SELECT COUNT(*) FROM scraped" 2>/dev/null || echo "?")
    PAIRS=$(wc -l ~/axentx/surrogate/data/training-jsonl/*.jsonl 2>/dev/null | tail -1 | awk '{print $1}' || echo "?")
    EP=$(wc -l ~/.claude/state/surrogate-memory/episodes.jsonl 2>/dev/null | awk '{print $1}' || echo "0")
    PLAN_FILE="$SURROGATE_HOME/active-plan.md"
    echo "${B}▸ Session${R}"
    echo "  cwd:            ${GR}$(pwd)${R}"
    echo "  project:        ${GR}${SURROGATE_MD:-"(no SURROGATE.md)"}${R}"
    echo "  episodes:       ${GR}${EP}${R}"
    if [[ -f "$PLAN_FILE" ]]; then
        DONE=$(grep -c '^\- \[x\]' "$PLAN_FILE" 2>/dev/null || echo 0)
        PENDING=$(grep -c '^\- \[ \]' "$PLAN_FILE" 2>/dev/null || echo 0)
        echo "  active plan:    ${GR}✅ done=$DONE  ⏳ pending=$PENDING${R}"
    else
        echo "  active plan:    ${GY}none${R}"
    fi
    echo ""
    echo "${B}▸ Corpus${R}"
    echo "  training pairs: ${GR}${PAIRS}${R}"
    echo "  scraped repos:  ${GR}${REPOS}${R}"
}

show_agents() {
    banner
    echo ""
    echo "${B}▸ Available agents (~/.claude/agents/)${R}"
    ls ~/.claude/agents/*.md 2>/dev/null | /usr/bin/sed 's|.*/||;s|.md$||' | sed 's/^/  /'
}

# ═══ Dispatch ═══
case "$MODE" in
    help) help_text ;;
    status) show_status ;;
    agents) show_agents ;;
    auto-dev) auto_dev_mode "$PROMPT" ;;
    monitor) monitor_mode ;;
    init-project) init_project ;;
    plan-mode)
        # --plan flag + task = architect only
        if [[ -n "$PROMPT" ]]; then plan_mode "$PROMPT"
        else
            # No task — show plan status
            bash ~/.claude/bin/surrogate-daemon.sh plan show
        fi
        ;;
    print)
        if [[ "$PERM_MODE" == "yolo" ]]; then run_agent "$PROMPT"
        else run_agent "$PROMPT"
        fi
        ;;
    interactive)
        if [[ -n "$WORKTREE" ]]; then
            git worktree add "$SURROGATE_HOME/worktrees/$WORKTREE" 2>/dev/null
            cd "$SURROGATE_HOME/worktrees/$WORKTREE" 2>/dev/null || true
        fi
        repl
        ;;
esac
